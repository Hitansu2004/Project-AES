<?xml version="1.0" encoding="UTF-8"?>
<!--
  AES Customer Portal — log layout

  Format:  HH:mm:ss.SSS  LEVEL  [thread] logger - message
  Goal:    short, scannable lines so the per-request log lines stand out and
           Hibernate/Security framework noise is silenced unless explicitly enabled.
-->
<!-- scan="true" is intentionally OFF: when the app runs from a Spring Boot
     fat-jar logback can't file-watch inside the nested archive, which makes
     it dump its full status table to the console at startup. -->
<configuration>

    <property name="LOG_PATTERN_CONSOLE"
              value="%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan([%-15.15thread]) %magenta(%-32.32logger{0}) - %msg%n"/>

    <property name="LOG_PATTERN_FILE"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%-15.15thread] %-32.32logger{0} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN_CONSOLE}</pattern>
        </encoder>
    </appender>

    <!-- Root: INFO, no SQL, no Spring Security DEBUG -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- App package — INFO by default; flip to DEBUG via application-dev.properties -->
    <logger name="com.aes" level="INFO"/>

    <!-- Frameworks: keep quiet so the request log is the loudest thing -->
    <logger name="org.hibernate"               level="WARN"/>
    <logger name="org.hibernate.SQL"           level="OFF"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="OFF"/>
    <logger name="org.hibernate.orm.jdbc"      level="OFF"/>
    <logger name="org.springframework"         level="WARN"/>
    <logger name="org.springframework.web"     level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.springframework.boot"    level="INFO"/>
    <logger name="com.zaxxer.hikari"           level="WARN"/>
    <logger name="org.flywaydb"                level="INFO"/>
    <logger name="org.apache.tomcat"           level="WARN"/>
    <logger name="org.apache.catalina"         level="WARN"/>

</configuration>
